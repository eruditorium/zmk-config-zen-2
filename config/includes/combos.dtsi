/* KEY POSITIONS (using keypos_def helpers)
╭─────────────────────┬─────────────────────╮
│ LT4 LT3 LT2 LT1 LT0 │ RT0 RT1 RT2 RT3 RT4 │
│ LM4 LM3 LM2 LM1 LM0 │ RM0 RM1 RM2 RM3 RM4 │
│ LB4 LB3 LB2 LB1 LB0 │ RB0 RB1 RB2 RB3 RB4 │
╰───────╮ LH2 LH1 LH0 │ RH0 RH1 RH2 ╭───────╯
        ╰─────────────┴─────────────╯       */

#define COMBO(NAME, BINDINGS, KEYPOS, LAYERS, TERM, QUICKTAP, ...) \
    combo_##NAME { \
        timeout-ms = <TERM>; \
        bindings = <BINDINGS>; \
        key-positions = <KEYPOS>; \
        layers = <LAYERS>; \
        require-prior-idle-ms = <QUICKTAP>; \
        __VA_ARGS__ \
    };

/ {
    combos {
        compatible = "zmk,combos";

COMBO(minus,  &kp MINUS,     LM1 LM2,     DEF,          80,  50)
COMBO(undrscr,&kp UNDERSCORE,RM1 RM2,     DEF,          80,  50)
COMBO(dqt, 	  &kp DQT,		 LB2 LB1,     DEF BRD SYM,  40, 100)
COMBO(sqt, 	  &kp SQT,		 LT2 LT1,     DEF BRD SYM,  40, 100)

COMBO(tab,    &kp TAB,       RT2 RT1,     DEF BRD SYM,  40, 100)
COMBO(bspc,   &kp BSPC,      RM2 RM3,     DEF BRD SYM,  40, 100)
COMBO(esc,    &kp ESC,       LT2 LT3, 	  DEF BRD SYM,  40,   0)

COMBO(lpar,   &kp LPAR,      LB1 LB0,     DEF BRD SYM,  40, 100)
COMBO(rpar,   &kp RPAR,      RB1 RB0,     DEF BRD SYM,  40, 100)
COMBO(lbkt,   &kp LBKT,      LM1 LM0,     DEF BRD SYM,  40, 100)
COMBO(rbkt,   &kp RBKT,      RM1 RM0,     DEF BRD SYM,  40, 100)
COMBO(lbkt,   &kp LBRC,      LT1 LT0,     DEF BRD SYM,  40, 100)
COMBO(rbkt,   &kp RBRC,      RT1 RT0,     DEF BRD SYM,  40, 100)

COMBO(capswd, &caps_word,    LM1 RM1,     DEF BRD,      60, 200)
COMBO(lock,   &kp LG(L),     LT1 LT0,     DEF BRD,      80, 500)

COMBO(winq,   &kp LA(F4),    LT3 LT2,     NAV,          80, 200)
COMBO(undo,   &kp LC(Z),     LB3 LB2,     NAV,          80,  50)

COMBO(calc,   &kp C_AL_CALC, RT0 RM0,     NAV,         200, 200)

COMBO(indbat, &ind_bat,      LT2 RT2,     FUN,         100, 200)
COMBO(indcon, &ind_con,      LT1 RT1,     FUN,         100, 200)
    };
};




        LeftBrace {
            bindings = <&kp LEFT_BRACE>;
            key-positions = <5 4>;
        };

        LeftBracket {
            bindings = <&kp LEFT_BRACKET>;
            key-positions = <16 17>;
        };

        LeftParenthesis {
            bindings = <&kp LEFT_PARENTHESIS>;
            key-positions = <28 29>;
        };

        RightBrace {
            bindings = <&kp RIGHT_BRACE>;
            key-positions = <6 7>;
        };

        RightBracket {
            bindings = <&kp RIGHT_BRACKET>;
            key-positions = <18 19>;
        };

        RightParenthesis {
            bindings = <&kp RIGHT_PARENTHESIS>;
            key-positions = <30 31>;
        };

        DoubleQuotes {
            bindings = <&kp DOUBLE_QUOTES>;
            key-positions = <28 27>;
        };

        Quote {
            bindings = <&kp SINGLE_QUOTE>;
            key-positions = <31 32>;
        };

        equal {
            bindings = <&kp EQUAL>;
            key-positions = <22 23>;
        };

        
        Word-Delete {
            bindings = <&kp LC(DEL)>;
            key-positions = <11 23>;
        };

        WordBackspace {
            bindings = <&kp LC(BACKSPACE)>;
            key-positions = <0 12>;
        };

        selectline {
            bindings = <&selectline>;
            key-positions = <36 37>;
        };

        selectword {
            bindings = <&selectword>;
            key-positions = <40 41>;
        };

        capsword {
            bindings = <&caps_word>;
            key-positions = <16 19>;
        };
    };
};