/* KEY POSITIONS (using keypos_def helpers)
╭─────────────────────┬─────────────────────╮
│ LT4 LT3 LT2 LT1 LT0 │ RT0 RT1 RT2 RT3 RT4 │
│ LM4 LM3 LM2 LM1 LM0 │ RM0 RM1 RM2 RM3 RM4 │
│ LB4 LB3 LB2 LB1 LB0 │ RB0 RB1 RB2 RB3 RB4 │
╰───────╮ LH2 LH1 LH0 │ RH0 RH1 RH2 ╭───────╯
        ╰─────────────┴─────────────╯       */

#define COMBO(NAME, BINDINGS, KEYPOS, LAYERS, TERM, QUICKTAP, ...) \
    combo_##NAME { \
        timeout-ms = <TERM>; \
        bindings = <BINDINGS>; \
        key-positions = <KEYPOS>; \
        layers = <LAYERS>; \
        require-prior-idle-ms = <QUICKTAP>; \
        __VA_ARGS__ \
    };

/ {
    combos {
        compatible = "zmk,combos";

COMBO(minus,  &kp MINUS,     LM2 LM1,     DEF,          80,  50)
COMBO(undrscr,&kp UNDERSCORE,RM1 RM2,     DEF,          80,  50)
COMBO(dqt, 	  &kp DQT,		 LB2 LB1,     DEF,          40, 100)
COMBO(sqt, 	  &kp SQT,		 RB1 RB2,     DEF,          40, 100)

COMBO(tab,    &kp TAB,       RT1 RT2,     DEF RAI LWR,  40, 100)
COMBO(bspc,   &kp BSPC,      RM2 RM3,     DEF RAI LWR,  40, 100)
COMBO(esc,    &kp ESC,       LT3 LT2, 	  DEF RAI LWR,  40,   0)

COMBO(lpar,   &kp LPAR,      LB1 LB0,     DEF RAI LWR,  40, 100)
COMBO(rpar,   &kp RPAR,      RB0 RB1,     DEF RAI LWR,  40, 100)
COMBO(lbkt,   &kp LBKT,      LM1 LM0,     DEF RAI LWR,  40, 100)
COMBO(rbkt,   &kp RBKT,      RM0 RM1,     DEF RAI LWR,  40, 100)
COMBO(lbrc,   &kp LBRC,      LT1 LT0,     DEF RAI LWR,  40, 100)
COMBO(rbrc,   &kp RBRC,      RT0 RT1,     DEF RAI LWR,  40, 100)

COMBO(equal,  &kp EQUAL,     RM3 RM4,     DEF RAI LWR,  40, 100)
COMBO(selln,  &selectline,   LB3 LB2,     DEF,		    40, 100)
COMBO(selwrd, &selectword,   LM3 LM2,     DEF,		    40, 100)

COMBO(capswd, &caps_word,    LM1 RM1,     DEF,          60, 200)
COMBO(lock,   &kp LG(L),     LT4 LT3,     DEF,          80, 500)

COMBO(winq,   &kp LA(F4),    LT3 LT2,     DEF,		    80, 200)
COMBO(undo,   &kp LC(Z),     LB3 LB2,     DEF,		    80,  50)

COMBO(calc,   &kp C_AL_CALC, RT0 RM0,     DEF,         200, 200)

/*COMBO(indbat, &ind_bat,    LT2 RT2,     ADJ,         100, 200)
COMBO(indcon, &ind_con,      LT1 RT1,     ADJ,         100, 200)*/

    };
};